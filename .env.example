PORT=3000
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key-here-generate-with-openssl-rand-hex-32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
SESSION_SECRET=your-session-secret-at-least-32-chars
DB_PATH=./data/calendar-invite.db
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/admin/calendars/callback/google

# Microsoft OAuth2 (Office 365 Calendar)
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/admin/calendars/callback/microsoft
MICROSOFT_TENANT_ID=common

# Zoho Calendar OAuth2
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REDIRECT_URI=http://localhost:3000/admin/calendars/zoho/callback
